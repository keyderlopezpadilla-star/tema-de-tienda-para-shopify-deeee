{%- comment -%} DEEE TODO — Password / coming soon page. {%- endcomment -%}
{%- liquid
  assign s = section.settings
-%}
<section class="section relative" style="min-height:100vh;display:grid;place-items:center;text-align:center">
  <div class="container container--narrow z-1 stack" style="--stack:1.75rem;align-items:center">
    <a href="{{ routes.root_url }}" class="header__logo" style="font-size:1.6rem">
      {%- if settings.logo != blank -%}
        <img src="{{ settings.logo | image_url: width: 360 }}" alt="{{ shop.name | escape }}" width="{{ settings.logo.width }}" height="{{ settings.logo.height }}" style="width:150px;height:auto">
      {%- else -%}
        {{ shop.name }}<span class="dot">.</span>
      {%- endif -%}
    </a>

    <span class="eyebrow">{{ s.eyebrow | default: 'Muy pronto' }}</span>
    <h1 class="display" style="font-size:clamp(2.5rem,7vw,5rem)">{{ s.heading | default: shop.name }}</h1>
    {%- if s.text != blank -%}<p class="lead" style="margin-inline:auto">{{ s.text }}</p>{%- endif -%}

    <div class="card {% if settings.glassmorphism %}glass{% endif %}" style="padding:2rem;max-width:26rem;width:100%">
      {%- form 'storefront_password', class: 'stack' -%}
        {%- if form.errors -%}<p class="form-status form-status--error">{{ form.errors.translated_fields.password | capitalize }} {{ form.errors.messages.password }}</p>{%- endif -%}
        <div class="search-field">
          <input type="password" name="password" placeholder="{{ s.password_placeholder | default: 'Contraseña' }}" required style="border:0;background:transparent">
          <button type="submit" class="btn btn--primary btn--sm"><span class="btn__label">{% render 'icon', name: 'arrow-right' %}</span></button>
        </div>
      {%- endform -%}
    </div>

    <div>{% render 'social-icons' %}</div>
    <p class="text-faint mono" style="font-size:.78rem">Powered by Shopify · <a href="/admin" class="link-underline">Entrar</a></p>
  </div>
</section>

{% schema %}
{
  "name": "Password page",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Muy pronto" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Estamos preparando algo especial" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Nuestra tienda abre enseguida. Déjanos tu correo y sé el primero en enterarte. ✨" },
    { "type": "text", "id": "password_placeholder", "label": "Password placeholder", "default": "Contraseña" }
  ]
}
{% endschema %}

{%- comment -%}
  DEEE TODO — Products by category with immersive 3D scroll animations.
  Each category block renders its collection's products in a grid or a
  horizontal snap-scroll rail. Cards flip up from depth via [data-scroll-3d]
  and react to the pointer with a subtle 3D tilt.
{%- endcomment -%}
{%- liquid
  assign s = section.settings
-%}
<section class="section category-showcase" data-accent-shift="{{ s.accent }}">
  <div class="ambient" aria-hidden="true">
    <div class="ambient__blob ambient__blob--3" style="opacity:.16"></div>
  </div>

  <div class="container z-1">
    {% render 'section-header',
      eyebrow: s.eyebrow,
      heading: s.heading,
      text: s.subheading,
      alignment: s.header_alignment,
      split: true %}

    <div class="category-stack" style="margin-top:clamp(2.5rem,5vw,4rem)">
      {%- for block in section.blocks -%}
        {%- liquid
          assign col = collections[block.settings.collection]
          assign heading = block.settings.heading | default: col.title | default: 'Categoría'
          assign accent = block.settings.accent | default: s.accent
          assign padded_index = forloop.index | prepend: '0' | slice: -2, 2
        -%}
        <article class="category-row" {{ block.shopify_attributes }} style="--cat-accent: {{ accent }}">
          <header class="category-row__head" {% if settings.scroll_reveal %}data-reveal{% endif %}>
            <div class="category-row__heading">
              <span class="category-row__index mono">{{ padded_index }}</span>
              <div>
                <h3 class="category-row__title" data-split>{{ heading }}</h3>
                {%- if block.settings.description != blank -%}
                  <p class="text-muted category-row__desc">{{ block.settings.description }}</p>
                {%- elsif col.description != blank -%}
                  <p class="text-muted category-row__desc">{{ col.description | strip_html | truncatewords: 18 }}</p>
                {%- endif -%}
              </div>
            </div>
            {%- if col != blank -%}
              <a class="btn btn--ghost category-row__link" href="{{ col.url }}" {% if settings.magnetic_buttons %}data-magnetic{% endif %}>
                <span class="btn__label">{{ s.link_label | default: 'Ver categoría' }} {% render 'icon', name: 'arrow-right' %}</span>
              </a>
            {%- endif -%}
          </header>

          {%- if col != blank and col.products.size > 0 -%}
            <div
              class="category-track {% if s.layout == 'scroll' %}category-track--scroll{% else %}product-grid product-grid--{{ s.columns }}{% endif %}"
              data-scroll-3d
            >
              {%- for product in col.products limit: s.products_per_category -%}
                {% render 'product-card', product: product, reveal: false, tilt: true %}
              {%- endfor -%}
            </div>
          {%- else -%}
            <div class="category-track {% if s.layout == 'scroll' %}category-track--scroll{% else %}product-grid product-grid--{{ s.columns }}{% endif %}" data-scroll-3d>
              {%- for i in (1..s.products_per_category) -%}
                <div class="product-card">
                  <div class="product-card__media">{{ 'product-1' | placeholder_svg_tag: 'placeholder' }}</div>
                  <div class="product-card__info">
                    <h3 class="product-card__title">Producto de ejemplo</h3>
                    <span class="price">{{ 1999 | money }}</span>
                  </div>
                </div>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Categorías (3D)",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Explora por categorías" },
    { "type": "textarea", "id": "heading", "label": "Heading", "default": "Encuentra justo lo que buscas" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Cada categoría, con su propio universo. Desliza y descubre." },
    {
      "type": "select",
      "id": "header_alignment",
      "label": "Header alignment",
      "options": [ { "value": "left", "label": "Left" }, { "value": "center", "label": "Center" } ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout de cada categoría",
      "options": [
        { "value": "grid", "label": "Rejilla" },
        { "value": "scroll", "label": "Carrusel horizontal" }
      ],
      "default": "scroll"
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Columnas (rejilla)",
      "options": [ { "value": "3", "label": "3" }, { "value": "4", "label": "4" } ],
      "default": "4"
    },
    { "type": "range", "id": "products_per_category", "label": "Productos por categoría", "min": 3, "max": 12, "step": 1, "default": 6 },
    { "type": "text", "id": "link_label", "label": "Texto del enlace", "default": "Ver categoría" },
    { "type": "color", "id": "accent", "label": "Ambient accent", "default": "#00f0ff" }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Categoría",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Colección" },
        { "type": "text", "id": "heading", "label": "Título (opcional)" },
        { "type": "textarea", "id": "description", "label": "Descripción (opcional)" },
        { "type": "color", "id": "accent", "label": "Color de acento" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Categorías (3D)",
      "blocks": [
        { "type": "category", "settings": { "heading": "Textil personalizado", "accent": "#fb2c36" } },
        { "type": "category", "settings": { "heading": "Papelería e impresión", "accent": "#00f0ff" } },
        { "type": "category", "settings": { "heading": "Regalos y detalles", "accent": "#b300ff" } }
      ]
    }
  ],
  "enabled_on": { "templates": ["index", "page", "collection"] }
}
{% endschema %}

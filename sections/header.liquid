{%- comment -%} DEEE TODO — Sticky header with mega menu, search & cart drawer trigger. {%- endcomment -%}
{%- liquid
  assign menu = section.settings.menu
  assign transparent = false
  if section.settings.transparent_on_home and template.name == 'index'
    assign transparent = true
  endif
-%}
<header
  class="header {% if transparent %}header--transparent{% endif %}"
  data-header
  data-hide-on-scroll="{{ section.settings.hide_on_scroll }}"
>
  <div class="header__inner">
    <button
      class="header__icon-btn header__menu-toggle"
      data-menu-toggle
      aria-expanded="false"
      aria-controls="MenuDrawer"
      aria-label="{{ 'accessibility.menu' | t }}"
    >
      <span class="hamburger"><span></span><span></span><span></span></span>
    </button>

    <a href="{{ routes.root_url }}" class="header__logo" aria-label="{{ shop.name }}">
      {%- if section.settings.logo != blank -%}
        <img
          src="{{ section.settings.logo | image_url: width: 400 }}"
          alt="{{ shop.name | escape }}"
          width="{{ section.settings.logo.width }}"
          height="{{ section.settings.logo.height }}"
          style="width:{{ section.settings.logo_width }}px;height:auto"
        >
      {%- else -%}
        {{ shop.name }}<span class="dot">.</span>
      {%- endif -%}
    </a>

    <nav class="header__nav" aria-label="{{ 'sections.header.menu' | t }}">
      {%- for link in menu.links -%}
        <div class="header__nav-item">
          <a
            href="{{ link.url }}"
            class="nav__link"
            {% if link.links != blank %}aria-haspopup="true" aria-expanded="false"{% endif %}
            {% if link.current %}aria-current="page"{% endif %}
          >
            {{ link.title }}
            {%- if link.links != blank -%}{% render 'icon', name: 'chevron-down', class: 'icon' %}{%- endif -%}
          </a>
          {%- if link.links != blank -%}
            <div class="mega">
              <div class="mega__grid">
                {%- for child in link.links -%}
                  <div class="mega__col">
                    <a href="{{ child.url }}" class="mega__col-title" style="display:block">{{ child.title }}</a>
                    {%- for grandchild in child.links -%}
                      <a href="{{ grandchild.url }}" class="mega__link">{{ grandchild.title }}</a>
                    {%- endfor -%}
                  </div>
                {%- endfor -%}
              </div>
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </nav>

    <div class="header__actions">
      {%- if section.settings.show_search -%}
        <button class="header__icon-btn" data-search-open aria-label="{{ 'accessibility.search' | t }}">
          {% render 'icon', name: 'search' %}
        </button>
      {%- endif -%}
      <a href="{{ routes.account_url }}" class="header__icon-btn" aria-label="{{ 'customer.account.title' | t }}">
        {% render 'icon', name: 'user' %}
      </a>
      <button class="header__icon-btn" data-cart-open aria-label="{{ 'accessibility.cart' | t }}">
        {% render 'icon', name: 'cart' %}
        <span class="cart-count {% if cart.item_count > 0 %}is-active{% endif %}" data-cart-count>{{ cart.item_count }}</span>
      </button>
    </div>
  </div>
</header>

{%- comment -%} Mobile drawer menu {%- endcomment -%}
<nav id="MenuDrawer" class="menu-drawer" data-menu-drawer data-closable aria-label="{{ 'sections.header.menu' | t }}" aria-hidden="true">
  {%- for link in menu.links -%}
    {%- if link.links != blank -%}
      <details class="menu-drawer__group">
        <summary class="menu-drawer__link">{{ link.title }} {% render 'icon', name: 'chevron-down', class: 'icon' %}</summary>
        <div class="stack" style="padding:.5rem 0 1rem 1rem">
          {%- for child in link.links -%}
            <a class="footer__link" href="{{ child.url }}">{{ child.title }}</a>
          {%- endfor -%}
        </div>
      </details>
    {%- else -%}
      <a class="menu-drawer__link" href="{{ link.url }}">{{ link.title }} {% render 'icon', name: 'chevron-right', class: 'icon' %}</a>
    {%- endif -%}
  {%- endfor -%}
  <div style="margin-top:2rem">{% render 'social-icons' %}</div>
</nav>

{% schema %}
{
  "name": "Header",
  "class": "section-header-wrapper",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo" },
    { "type": "range", "id": "logo_width", "label": "Logo width", "min": 60, "max": 220, "step": 10, "unit": "px", "default": 130 },
    { "type": "link_list", "id": "menu", "label": "Menu", "default": "main-menu" },
    { "type": "checkbox", "id": "show_search", "label": "Show search", "default": true },
    { "type": "checkbox", "id": "transparent_on_home", "label": "Transparent on homepage", "default": true },
    { "type": "checkbox", "id": "hide_on_scroll", "label": "Hide header on scroll down", "default": true }
  ]
}
{% endschema %}

{%- comment -%} DEEE TODO — Gift card display. {%- endcomment -%}
{% layout none %}
<!doctype html>
<html lang="{{ request.locale.iso_code }}" class="no-js">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="robots" content="noindex, nofollow">
    <title>{{ 'gift_cards.issued.title' | t: value: gift_card.initial_value | money, shop: shop.name }}</title>
    {% render 'meta-tags' %}
    {% render 'css-variables' %}
    {{ 'base.css' | asset_url | stylesheet_tag }}
    {{ 'components.css' | asset_url | stylesheet_tag }}
    <script src="https://cdn.shopify.com/shopifycloud/shopify/assets/themes/gift-card/qr-cptl1QGs.js" defer></script>
  </head>
  <body class="template-gift-card">
    <div class="ambient" aria-hidden="true">
      <div class="ambient__blob ambient__blob--1"></div>
      <div class="ambient__blob ambient__blob--2"></div>
    </div>
    <section class="section" style="min-height:100vh;display:grid;place-items:center">
      <div class="container container--narrow z-1 text-center stack" style="--stack:1.5rem;align-items:center">
        <a href="{{ shop.url }}" class="header__logo" style="font-size:1.5rem">{{ shop.name }}<span class="dot">.</span></a>
        <span class="eyebrow">Tarjeta regalo</span>
        <div class="card {% if settings.glassmorphism %}glass{% endif %} glow-ring" style="padding:2.5rem;max-width:26rem;width:100%">
          <div class="display text-gradient" style="font-size:clamp(2.5rem,10vw,4rem)">{{ gift_card.balance | money }}</div>
          {%- if gift_card.balance != gift_card.initial_value -%}
            <p class="text-muted">de {{ gift_card.initial_value | money }}</p>
          {%- endif -%}
          <div style="margin:1.5rem auto;display:grid;place-items:center">
            <div id="QrCode" data-identifier="{{ gift_card.qr_identifier }}"></div>
          </div>
          <div class="mono" style="font-size:1.1rem;letter-spacing:.15em;padding:.75rem;border:1px dashed var(--color-line-strong);border-radius:var(--radius)">
            {{ gift_card.code | format_code }}
          </div>
        </div>
        <button class="btn btn--primary" onclick="navigator.clipboard && navigator.clipboard.writeText('{{ gift_card.code | remove: ' ' }}')">
          <span class="btn__label">{{ 'gift_cards.issued.copy_code' | t }}</span>
        </button>
        {%- if gift_card.expired == false and gift_card.expires_on -%}
          <p class="text-faint mono" style="font-size:.8rem">Válida hasta {{ gift_card.expires_on | date: '%d/%m/%Y' }}</p>
        {%- endif -%}
      </div>
    </section>
  </body>
</html>

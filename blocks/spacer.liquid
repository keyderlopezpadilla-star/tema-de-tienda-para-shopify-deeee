{%- comment -%} DEEE TODO — Vertical spacer / divider theme block. {%- endcomment -%}
<div class="block-spacer" style="height:{{ block.settings.height }}px" {{ block.shopify_attributes }}>
  {%- if block.settings.show_divider -%}<hr class="divider" style="margin-top:{{ block.settings.height | divided_by: 2 }}px">{%- endif -%}
</div>

{% schema %}
{
  "name": "Spacer",
  "settings": [
    { "type": "range", "id": "height", "label": "Height", "min": 8, "max": 160, "step": 4, "unit": "px", "default": 48 },
    { "type": "checkbox", "id": "show_divider", "label": "Show divider line", "default": false }
  ],
  "presets": [{ "name": "Spacer" }]
}
{% endschema %}


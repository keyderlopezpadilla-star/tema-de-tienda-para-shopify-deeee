{%- comment -%} DEEE TODO — Image + text with parallax and depth. {%- endcomment -%}
{%- liquid
  assign s = section.settings
-%}
<section class="section overflow-clip" data-parallax-scope data-accent-shift="{{ s.accent }}">
  <div class="container">
    <div class="grid" style="--gap:clamp(1.5rem,5vw,4rem);grid-template-columns:repeat(auto-fit,minmax(300px,1fr));align-items:center">
      <div class="relative {% if s.layout == 'text_first' %}order-2{% endif %}" style="{% if s.layout == 'text_first' %}order:2{% endif %}">
        <div class="media {% if s.image_shape == 'rounded' %}ratio-portrait{% else %}ratio-square{% endif %}" style="border-radius:var(--radius-xl);overflow:hidden" data-scroll-zoom>
          {% render 'responsive-image', image: s.image, ratio: s.image_shape, sizes: '(min-width:990px) 50vw, 90vw' %}
        </div>
        {%- if s.badge != blank -%}
          <span class="badge {% if settings.glassmorphism %}glass{% endif %}" style="position:absolute;bottom:1rem;left:1rem;font-size:.85rem;padding:.6rem 1rem" data-parallax="-0.15">{{ s.badge }}</span>
        {%- endif -%}
      </div>

      <div class="stack" style="--stack:1.5rem">
        {% render 'section-header', eyebrow: s.eyebrow, heading: s.heading, alignment: 'left', split: true %}
        {%- if s.text != blank -%}<div class="rte text-muted" {% if settings.scroll_reveal %}data-reveal{% endif %}>{{ s.text }}</div>{%- endif -%}
        {%- if s.button_label != blank -%}
          <div {% if settings.scroll_reveal %}data-reveal{% endif %}>
            <a class="btn btn--primary btn--lg" href="{{ s.button_link }}" {% if settings.magnetic_buttons %}data-magnetic{% endif %}>
              <span class="btn__label">{{ s.button_label }} {% render 'icon', name: 'arrow-right' %}</span>
            </a>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Image with text",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    {
      "type": "select",
      "id": "image_shape",
      "label": "Image shape",
      "options": [ { "value": "square", "label": "Square" }, { "value": "portrait", "label": "Portrait" }, { "value": "landscape", "label": "Landscape" } ],
      "default": "portrait"
    },
    { "type": "text", "id": "badge", "label": "Badge", "default": "Hecho en Algemesí" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "La copistería de siempre" },
    { "type": "textarea", "id": "heading", "label": "Heading", "default": "Con un puntito gamberro" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Que no te engañe el rollo futurista: seguimos siendo esa copistería de barrio donde entras con un pendrive y sales con todo resuelto. Solo que ahora también lo diseñas desde el sofá.</p>" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Envía o ajusta tu copia" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [ { "value": "image_first", "label": "Image first" }, { "value": "text_first", "label": "Text first" } ],
      "default": "image_first"
    },
    { "type": "color", "id": "accent", "label": "Ambient accent", "default": "#fb2c36" }
  ],
  "presets": [{ "name": "Image with text" }],
  "enabled_on": { "templates": ["index", "page", "product", "collection"] }
}
{% endschema %}

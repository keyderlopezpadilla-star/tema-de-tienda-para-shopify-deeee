<section class="section">
  <div class="container" style="max-width:32rem">
    <h1 class="h1" style="margin-bottom:1.5rem" data-split>Nueva contraseña</h1>
    {%- form 'reset_customer_password', class: 'card' -%}
      <div style="padding:1.75rem;display:grid;gap:1rem">
        {%- if form.errors -%}<p class="form-status form-status--error">{{ form.errors | default_errors }}</p>{%- endif -%}
        <div class="field">
          <label class="field__label" for="ResetPassword">{{ 'customer.login.password' | t }}</label>
          <input class="input" type="password" id="ResetPassword" name="customer[password]" autocomplete="new-password" required>
        </div>
        <div class="field">
          <label class="field__label" for="ResetConfirm">Confirmar contraseña</label>
          <input class="input" type="password" id="ResetConfirm" name="customer[password_confirmation]" autocomplete="new-password" required>
        </div>
        <button class="btn btn--primary btn--full btn--lg" type="submit"><span class="btn__label">Restablecer contraseña</span></button>
      </div>
    {%- endform -%}
  </div>
</section>

{% schema %}
{ "name": "Reset password", "settings": [] }
{% endschema %}


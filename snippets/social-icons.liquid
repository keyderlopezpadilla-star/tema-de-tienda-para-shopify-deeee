{%- comment -%} Renders configured social links from theme settings. {%- endcomment -%}
{%- liquid
  assign has_social = false
  if settings.social_instagram != blank or settings.social_facebook != blank or settings.social_tiktok != blank or settings.social_x != blank or settings.social_youtube != blank or settings.social_whatsapp != blank
    assign has_social = true
  endif
-%}
{%- if has_social -%}
  <div class="social" role="list" aria-label="{{ 'general.social.follow' | t }}">
    {%- if settings.social_instagram != blank -%}
      <a href="{{ settings.social_instagram }}" target="_blank" rel="noopener" aria-label="Instagram">{% render 'icon', name: 'instagram' %}</a>
    {%- endif -%}
    {%- if settings.social_tiktok != blank -%}
      <a href="{{ settings.social_tiktok }}" target="_blank" rel="noopener" aria-label="TikTok">{% render 'icon', name: 'tiktok' %}</a>
    {%- endif -%}
    {%- if settings.social_facebook != blank -%}
      <a href="{{ settings.social_facebook }}" target="_blank" rel="noopener" aria-label="Facebook">{% render 'icon', name: 'facebook' %}</a>
    {%- endif -%}
    {%- if settings.social_x != blank -%}
      <a href="{{ settings.social_x }}" target="_blank" rel="noopener" aria-label="X">{% render 'icon', name: 'x' %}</a>
    {%- endif -%}
    {%- if settings.social_youtube != blank -%}
      <a href="{{ settings.social_youtube }}" target="_blank" rel="noopener" aria-label="YouTube">{% render 'icon', name: 'youtube' %}</a>
    {%- endif -%}
    {%- if settings.social_whatsapp != blank -%}
      <a href="{{ settings.social_whatsapp }}" target="_blank" rel="noopener" aria-label="WhatsApp">{% render 'icon', name: 'whatsapp' %}</a>
    {%- endif -%}
  </div>
{%- endif -%}


{%- liquid
  assign product = product
  assign current_variant = product.selected_or_first_available_variant
-%}
<section class="section" data-product data-recently-viewed-current="{{ product.handle }}">
  <div class="container">
    {%- comment -%} Breadcrumbs {%- endcomment -%}
    <nav class="mono text-muted" style="font-size:.82rem;margin-bottom:1.5rem" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}" class="link-underline">Inicio</a>
      {%- if collection %} / <a href="{{ collection.url }}" class="link-underline">{{ collection.title }}</a>{% endif -%}
      / <span>{{ product.title }}</span>
    </nav>

    <div class="product">
      {% render 'product-media-gallery', product: product %}

      <div class="product__info">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'vendor' -%}
              {%- if product.vendor != blank -%}
                <div class="product-card__vendor" {{ block.shopify_attributes }}>{{ product.vendor }}</div>
              {%- endif -%}

            {%- when 'title' -%}
              <h1 class="h1" style="font-size:clamp(1.8rem,4vw,2.8rem)" {{ block.shopify_attributes }}>{{ product.title }}</h1>

            {%- when 'rating' -%}
              <div {{ block.shopify_attributes }}>{% render 'rating', product: product %}</div>

            {%- when 'price' -%}
              <div class="cluster" style="--gap:.75rem" {{ block.shopify_attributes }}>
                <span class="price price--large {% if current_variant.compare_at_price > current_variant.price %}price--on-sale{% endif %}">
                  <span class="price__regular" data-product-compare {% unless current_variant.compare_at_price > current_variant.price %}hidden{% endunless %}>{{ current_variant.compare_at_price | money }}</span>
                  <span data-product-price>{{ current_variant.price | money }}</span>
                </span>
                {%- if product.metafields.custom.delivery_time -%}
                  <span class="badge badge--neon">🚚 {{ product.metafields.custom.delivery_time }}</span>
                {%- endif -%}
              </div>

            {%- when 'description_short' -%}
              {%- if block.settings.text != blank -%}
                <p class="text-muted" {{ block.shopify_attributes }}>{{ block.settings.text }}</p>
              {%- elsif product.metafields.descriptors.subtitle -%}
                <p class="text-muted" {{ block.shopify_attributes }}>{{ product.metafields.descriptors.subtitle }}</p>
              {%- endif -%}

            {%- when 'variant_picker' -%}
              <div {{ block.shopify_attributes }}>{% render 'product-variant-picker', product: product %}</div>

            {%- when 'buy_buttons' -%}
              <div {{ block.shopify_attributes }}>{% render 'buy-buttons', product: product, section_id: section.id %}</div>

            {%- when 'stock' -%}
              <div class="cluster" style="--gap:.5rem;font-size:.9rem" {{ block.shopify_attributes }}>
                {%- if current_variant.available -%}
                  <span style="width:.6rem;height:.6rem;border-radius:50%;background:var(--color-neon-green);box-shadow:0 0 10px var(--color-neon-green)"></span>
                  <span class="text-muted">{% if current_variant.inventory_management and current_variant.inventory_quantity <= 5 and current_variant.inventory_quantity > 0 %}{{ 'products.product.low_stock' | t }}{% else %}{{ 'products.product.in_stock' | t }}{% endif %}</span>
                {%- else -%}
                  <span style="width:.6rem;height:.6rem;border-radius:50%;background:var(--color-text-faint)"></span>
                  <span class="text-muted">{{ 'products.product.out_of_stock' | t }}</span>
                {%- endif -%}
              </div>

            {%- when 'icons' -%}
              <div class="grid" style="--gap:.75rem;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));margin-top:.5rem" {{ block.shopify_attributes }}>
                {%- assign items = block.settings.items | newline_to_br | split: '<br />' -%}
                {%- for item in items -%}
                  {%- assign parts = item | strip | split: '|' -%}
                  {%- if parts.size > 0 and parts.first != blank -%}
                    <div class="cluster" style="--gap:.5rem;font-size:.85rem">
                      <span style="color:var(--color-neon-cyan)">{% render 'icon', name: 'check' %}</span>
                      <span class="text-muted">{{ parts.first | strip }}</span>
                    </div>
                  {%- endif -%}
                {%- endfor -%}
              </div>

            {%- when 'description' -%}
              {%- if product.description != blank -%}
                <div class="accordion" data-accordion-single style="margin-top:.5rem" {{ block.shopify_attributes }}>
                  <div class="accordion__item">
                    <button class="accordion__trigger" type="button" data-accordion-trigger aria-expanded="true">
                      <span>{{ 'products.product.description' | t }}</span><span class="accordion__icon">{% render 'icon', name: 'plus' %}</span>
                    </button>
                    <div class="accordion__panel"><div><div class="accordion__body rte">{{ product.description }}</div></div></div>
                  </div>
                </div>
              {%- endif -%}

            {%- when 'collapsible' -%}
              <div class="accordion" data-accordion-single {{ block.shopify_attributes }}>
                <div class="accordion__item">
                  <button class="accordion__trigger" type="button" data-accordion-trigger aria-expanded="false">
                    <span>{{ block.settings.heading }}</span><span class="accordion__icon">{% render 'icon', name: 'plus' %}</span>
                  </button>
                  <div class="accordion__panel"><div><div class="accordion__body rte">{{ block.settings.content }}</div></div></div>
                </div>
              </div>

            {%- when 'share' -%}
              <div class="cluster" style="--gap:.5rem;margin-top:.5rem" {{ block.shopify_attributes }}>
                <span class="text-muted mono" style="font-size:.8rem">{{ 'products.product.share' | t }}:</span>
                {% render 'social-icons' %}
              </div>

            {%- when '@app' -%}
              {% render block %}
          {%- endcase -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

  {%- comment -%} Sticky add-to-cart bar {%- endcomment -%}
  <div class="product__sticky-atc {% if settings.glassmorphism %}glass{% endif %}" data-sticky-atc>
    <div class="cluster" style="--gap:.75rem;min-width:0">
      {%- if product.featured_media -%}
        <img src="{{ product.featured_media | image_url: width: 96 }}" alt="" width="44" height="44" style="width:44px;height:44px;border-radius:8px;object-fit:cover" loading="lazy">
      {%- endif -%}
      <div style="min-width:0">
        <div style="font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:40vw">{{ product.title }}</div>
        <span class="price"><span data-product-price>{{ current_variant.price | money }}</span></span>
      </div>
    </div>
    <button class="btn btn--primary" type="button" data-sticky-add>
      <span class="btn__label">{{ 'products.product.add_to_cart' | t }}</span>
    </button>
  </div>

  <script type="application/json" data-product-json>
    {{ product | json }}
  </script>
</section>

{% schema %}
{
  "name": "Product",
  "tag": "section",
  "blocks": [
    { "type": "vendor", "name": "Vendor", "limit": 1 },
    { "type": "title", "name": "Title", "limit": 1 },
    { "type": "rating", "name": "Rating", "limit": 1 },
    { "type": "price", "name": "Price", "limit": 1 },
    {
      "type": "description_short",
      "name": "Short description",
      "limit": 1,
      "settings": [ { "type": "textarea", "id": "text", "label": "Text (optional, falls back to metafield)" } ]
    },
    { "type": "variant_picker", "name": "Variant picker", "limit": 1 },
    { "type": "buy_buttons", "name": "Buy buttons", "limit": 1 },
    { "type": "stock", "name": "Stock status", "limit": 1 },
    {
      "type": "icons",
      "name": "Feature icons",
      "limit": 1,
      "settings": [ { "type": "textarea", "id": "items", "label": "One feature per line", "default": "Calidad premium\nEnvío 24-48h\nPago seguro SSL\nHecho en Algemesí" } ]
    },
    { "type": "description", "name": "Full description", "limit": 1 },
    {
      "type": "collapsible",
      "name": "Collapsible row",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Envío y devoluciones" },
        { "type": "richtext", "id": "content", "label": "Content", "default": "<p>Envío express 24-48h a toda España. Devoluciones sencillas en 14 días.</p>" }
      ]
    },
    { "type": "share", "name": "Share", "limit": 1 },
    { "type": "@app" }
  ],
  "settings": []
}
{% endschema %}


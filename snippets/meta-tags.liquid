{%- comment -%}
  SEO meta: description, Open Graph, Twitter Cards, and JSON-LD structured data.
{%- endcomment -%}
{%- liquid
  if page_description
    assign meta_description = page_description
  elsif template.name == 'product' and product.description != blank
    assign meta_description = product.description | strip_html | truncatewords: 50
  else
    assign meta_description = shop.description | default: shop.name
  endif

  if template.name == 'product' and product.featured_media
    assign share_image = product.featured_media
  elsif template.name == 'article' and article.image
    assign share_image = article.image
  elsif template.name == 'collection' and collection.image
    assign share_image = collection.image
  elsif settings.social_share_image
    assign share_image = settings.social_share_image
  elsif settings.logo
    assign share_image = settings.logo
  endif
-%}
<meta name="description" content="{{ meta_description | escape }}">

<meta property="og:site_name" content="{{ shop.name }}">
<meta property="og:url" content="{{ canonical_url }}">
<meta property="og:title" content="{{ page_title | escape }}">
<meta property="og:type" content="{% if template.name == 'product' %}product{% elsif template.name == 'article' %}article{% else %}website{% endif %}">
<meta property="og:description" content="{{ meta_description | escape }}">
{%- if share_image -%}
  <meta property="og:image" content="https:{{ share_image | image_url: width: 1200 }}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
{%- endif -%}
<meta property="og:locale" content="{{ request.locale.iso_code }}">

<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ page_title | escape }}">
<meta name="twitter:description" content="{{ meta_description | escape }}">
{%- if share_image -%}
  <meta name="twitter:image" content="https:{{ share_image | image_url: width: 1200 }}">
{%- endif -%}

{%- comment -%} Organization / WebSite structured data {%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": {{ shop.name | json }},
  "url": {{ shop.url | append: routes.root_url | json }},
  {% if settings.logo %}"logo": "https:{{ settings.logo | image_url: width: 400 }}",{% endif %}
  "sameAs": [
    {%- assign socials = '' -%}
    {%- if settings.social_instagram != blank %}{{ settings.social_instagram | json }},{% endif -%}
    {%- if settings.social_facebook != blank %}{{ settings.social_facebook | json }},{% endif -%}
    {%- if settings.social_tiktok != blank %}{{ settings.social_tiktok | json }},{% endif -%}
    {%- if settings.social_youtube != blank %}{{ settings.social_youtube | json }}{% endif -%}
  ]
}
</script>

{%- if template.name == 'index' -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": {{ shop.name | json }},
    "url": {{ shop.url | append: routes.root_url | json }},
    "potentialAction": {
      "@type": "SearchAction",
      "target": {{ shop.url | append: routes.search_url | append: '?q={search_term_string}' | json }},
      "query-input": "required name=search_term_string"
    }
  }
  </script>
{%- endif -%}

{%- if template.name == 'product' -%}
  {%- assign current_variant = product.selected_or_first_available_variant -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": {{ product.title | json }},
    "url": {{ shop.url | append: product.url | json }},
    {% if product.featured_media %}"image": "https:{{ product.featured_media | image_url: width: 1200 }}",{% endif %}
    "description": {{ product.description | strip_html | json }},
    "brand": { "@type": "Brand", "name": {{ product.vendor | json }} },
    "sku": {{ current_variant.sku | json }},
    "offers": {
      "@type": "Offer",
      "priceCurrency": {{ cart.currency.iso_code | json }},
      "price": {{ current_variant.price | divided_by: 100.0 | json }},
      "availability": "{% if current_variant.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
      "url": {{ shop.url | append: product.url | json }}
    }
  }
  </script>
{%- endif -%}

{%- if template.name == 'article' -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": {{ article.title | json }},
    {% if article.image %}"image": "https:{{ article.image | image_url: width: 1200 }}",{% endif %}
    "datePublished": {{ article.published_at | date: '%Y-%m-%d' | json }},
    "author": { "@type": "Person", "name": {{ article.author | json }} },
    "publisher": { "@type": "Organization", "name": {{ shop.name | json }} }
  }
  </script>
{%- endif -%}

{%- if template.name == 'collection' or template.name == 'product' -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": {{ 'Inicio' | json }}, "item": {{ shop.url | append: routes.root_url | json }} }
      {%- if template.name == 'collection' -%}
        ,{ "@type": "ListItem", "position": 2, "name": {{ collection.title | json }}, "item": {{ shop.url | append: collection.url | json }} }
      {%- elsif template.name == 'product' and collection -%}
        ,{ "@type": "ListItem", "position": 2, "name": {{ collection.title | json }}, "item": {{ shop.url | append: collection.url | json }} }
        ,{ "@type": "ListItem", "position": 3, "name": {{ product.title | json }}, "item": {{ shop.url | append: product.url | json }} }
      {%- endif -%}
    ]
  }
  </script>
{%- endif -%}

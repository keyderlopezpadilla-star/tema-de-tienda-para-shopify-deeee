{%- comment -%} DEEE TODO — Static page content. {%- endcomment -%}
<section class="section">
  <div class="container container--narrow">
    {%- if section.settings.show_title -%}
      <h1 class="h1" style="margin-bottom:2rem" data-split>{{ page.title }}</h1>
    {%- endif -%}
    <div class="rte" {% if settings.scroll_reveal %}data-reveal{% endif %}>{{ page.content }}</div>
  </div>
</section>

{% schema %}
{
  "name": "Page",
  "settings": [
    { "type": "checkbox", "id": "show_title", "label": "Show page title", "default": true }
  ]
}
{% endschema %}

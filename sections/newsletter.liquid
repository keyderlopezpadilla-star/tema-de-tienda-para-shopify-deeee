{%- comment -%} DEEE TODO — Newsletter band with gradient glow. {%- endcomment -%}
{%- liquid
  assign s = section.settings
-%}
<section class="section" data-accent-shift="{{ s.accent }}">
  <div class="container">
    <div class="card {% if settings.glassmorphism %}glass{% endif %} relative overflow-clip" style="padding:clamp(2rem,6vw,4.5rem);text-align:center">
      <div class="ambient" aria-hidden="true"><div class="ambient__blob ambient__blob--1" style="opacity:.25"></div></div>
      <div class="stack z-1" style="--stack:1.25rem;align-items:center;max-width:44rem;margin-inline:auto">
        {%- if s.eyebrow != blank -%}<span class="eyebrow" {% if settings.scroll_reveal %}data-reveal{% endif %}>{{ s.eyebrow }}</span>{%- endif -%}
        {%- if s.heading != blank -%}<h2 class="h1" data-split>{{ s.heading }}</h2>{%- endif -%}
        {%- if s.text != blank -%}<p class="lead" style="margin-inline:auto">{{ s.text }}</p>{%- endif -%}
        {%- form 'customer', class: 'newsletter-form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          {%- if form.posted_successfully? -%}
            <p class="form-status form-status--success">{{ 'general.newsletter.success' | t }}</p>
          {%- else -%}
            <div class="search-field" style="max-width:26rem;margin-inline:auto">
              <input type="email" name="contact[email]" required placeholder="{{ 'general.newsletter.label' | t }}" aria-label="{{ 'general.newsletter.label' | t }}" style="border:0;background:transparent">
              <button type="submit" class="btn btn--primary" {% if settings.magnetic_buttons %}data-magnetic{% endif %}>
                <span class="btn__label">{{ 'general.newsletter.button' | t }}</span>
              </button>
            </div>
          {%- endif -%}
        {%- endform -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Newsletter" },
    { "type": "textarea", "id": "heading", "label": "Heading", "default": "Únete a la fábrica de ideas" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Novedades, ofertas y un poquito de rollo gamberro en tu correo." },
    { "type": "color", "id": "accent", "label": "Ambient accent", "default": "#b300ff" }
  ],
  "presets": [{ "name": "Newsletter" }],
  "enabled_on": { "templates": ["*"] }
}
{% endschema %}

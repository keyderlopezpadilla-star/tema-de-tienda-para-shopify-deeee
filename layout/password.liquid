<!doctype html>
<html lang="{{ request.locale.iso_code }}" class="no-js">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
    <meta name="theme-color" content="{{ settings.color_background }}">
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 64 }}">
    {%- endif -%}

    <title>{{ shop.name }}</title>
    <meta name="description" content="{{ page_description | escape }}">

    {% render 'meta-tags' %}
    {% render 'css-variables' %}
    {{ content_for_header }}

    {{ 'base.css' | asset_url | stylesheet_tag }}
    {{ 'components.css' | asset_url | stylesheet_tag }}
  </head>

  <body class="template-password">
    <div class="ambient">
      <div class="ambient__blob ambient__blob--1"></div>
      <div class="ambient__blob ambient__blob--2"></div>
      <div class="ambient__blob ambient__blob--3"></div>
    </div>

    {{ content_for_layout }}

    <div class="overlay" data-overlay></div>
    <script src="{{ 'theme.js' | asset_url }}" defer></script>
  </body>
</html>

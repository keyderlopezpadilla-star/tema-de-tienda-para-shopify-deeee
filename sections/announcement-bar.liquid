{%- comment -%} DEEE TODO — Rotating announcement bar. {%- endcomment -%}
{%- if section.blocks.size > 0 -%}
  <div class="announcement" data-announcement>
    <div class="announcement__inner">
      {%- for block in section.blocks -%}
        <span class="announcement__item" {{ block.shopify_attributes }} {% if section.blocks.size > 1 and forloop.index > 1 %}hidden{% endif %}>
          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}">{{ block.settings.text }}</a>
          {%- else -%}
            {{ block.settings.text }}
          {%- endif -%}
        </span>
      {%- endfor -%}
    </div>
  </div>

  {%- if section.blocks.size > 1 -%}
    <script>
      (function () {
        var items = document.querySelectorAll('[data-announcement] .announcement__item');
        if (items.length < 2) return;
        var i = 0;
        setInterval(function () {
          items[i].hidden = true;
          i = (i + 1) % items.length;
          items[i].hidden = false;
        }, {{ section.settings.rotate_speed | times: 1000 }});
      })();
    </script>
  {%- endif -%}
{%- endif -%}

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    { "type": "range", "id": "rotate_speed", "label": "Rotation speed (s)", "min": 3, "max": 12, "step": 1, "default": 5 }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "Envío express 24-48h a toda España 🚚" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement bar",
      "blocks": [
        { "type": "announcement", "settings": { "text": "Envío express 24-48h a toda España 🚚" } },
        { "type": "announcement", "settings": { "text": "Diseña tu producto y recíbelo en casa ✨" } }
      ]
    }
  ]
}
{% endschema %}

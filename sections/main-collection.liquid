{%- comment -%} DEEE TODO — Collection page with AJAX facets, sorting & infinite scroll. {%- endcomment -%}
{%- assign s = section.settings -%}
<section
  class="section"
  data-facets-container
  data-section-id="{{ section.id }}"
  data-ajax="{{ s.ajax_filtering }}"
  data-infinite="{% if s.ajax_filtering and s.enable_infinite_scroll %}true{% else %}false{% endif %}"
  aria-busy="false"
>
  <div class="container">
    {%- comment -%} Banner {%- endcomment -%}
    <div class="collection-banner" style="margin-bottom:2rem" data-parallax-scope>
      {%- if s.show_banner_image and collection.image -%}
        <div class="media ratio-wide overflow-clip" style="border-radius:var(--radius-xl);position:relative" data-scroll-zoom>
          {% render 'responsive-image', image: collection.image, ratio: 'wide', sizes: '100vw', loading: 'eager', fetchpriority: 'high' %}
          <div style="position:absolute;inset:0;background:linear-gradient(0deg, rgba(var(--color-bg-rgb),.9), rgba(var(--color-bg-rgb),.2));display:flex;align-items:flex-end;padding:clamp(1.5rem,4vw,3rem)">
            <div>
              <nav class="collection-hero__breadcrumb" aria-label="Breadcrumb"><a href="{{ routes.root_url }}" class="link-underline">Inicio</a> / <span>{{ collection.title }}</span></nav>
              <h1 class="display" style="font-size:clamp(2rem,5vw,3.5rem)" data-split>{{ collection.title }}</h1>
              {%- if collection.description != blank and s.show_description -%}<div class="lead">{{ collection.description | strip_html | truncatewords: 30 }}</div>{%- endif -%}
              <span class="badge collection-hero__count">{{ collection.all_products_count }} productos</span>
            </div>
          </div>
        </div>
      {%- else -%}
        <div class="collection-hero" data-reveal>
          <nav class="collection-hero__breadcrumb" aria-label="Breadcrumb"><a href="{{ routes.root_url }}" class="link-underline">Inicio</a> / <span>{{ collection.title | default: 'Productos' }}</span></nav>
          <h1 class="display" style="font-size:clamp(2rem,5vw,3.5rem)" data-split>{{ collection.title | default: 'Productos' }}</h1>
          {%- if collection.description != blank and s.show_description -%}<div class="lead" style="margin-top:1rem">{{ collection.description }}</div>{%- endif -%}
          <span class="badge collection-hero__count">{% render 'icon', name: 'sparkles' %} {{ collection.all_products_count }} productos</span>
        </div>
      {%- endif -%}
    </div>

    {%- if s.show_category_nav -%}
      <nav class="category-nav" aria-label="Categorías">
        <a href="{{ routes.all_products_collection_url }}" class="category-chip {% if collection.handle == 'all' or collection.handle == blank %}is-active{% endif %}">
          {% render 'icon', name: 'sparkles', class: 'icon' %} Todo
        </a>
        {%- if s.category_menu != blank and s.category_menu.links.size > 0 -%}
          {%- for link in s.category_menu.links -%}
            <a href="{{ link.url }}" class="category-chip {% if link.current %}is-active{% endif %}">{{ link.title }}</a>
          {%- endfor -%}
        {%- else -%}
          {%- for c in collections -%}
            {%- unless c.handle == 'all' or c.handle == 'frontpage' -%}
              <a href="{{ c.url }}" class="category-chip {% if c.handle == collection.handle %}is-active{% endif %}">{{ c.title }}</a>
            {%- endunless -%}
          {%- endfor -%}
        {%- endif -%}
      </nav>
    {%- endif -%}

    {%- if s.enable_filtering or s.enable_sorting -%}
      {% render 'facets', results: collection, enable_filtering: s.enable_filtering, enable_sorting: s.enable_sorting %}
    {%- endif -%}

    {%- paginate collection.products by s.products_per_page -%}
    {%- if collection.products.size > 0 -%}
      <div class="product-grid product-grid--{{ s.columns }}" data-facets-grid style="margin-top:1.5rem">
        {%- for product in collection.products -%}
          {% render 'product-card', product: product, reveal: false, tilt: true, image_ratio: s.image_ratio %}
        {%- endfor -%}
      </div>

      {%- comment -%} "Cargar más" is a full-reload link to the next page so images always refresh. {%- endcomment -%}
      {%- if paginate.next -%}
        <div class="text-center" style="margin-top:clamp(2.5rem,5vw,4rem)">
          <a href="{{ paginate.next.url }}" class="btn btn--ghost btn--lg" rel="next" {% if settings.magnetic_buttons %}data-magnetic{% endif %}>
            <span class="btn__label">{{ 'general.pagination.load_more' | t }}</span>
          </a>
        </div>
      {%- endif -%}
      {% render 'pagination', paginate: paginate %}
    {%- else -%}
      <div class="cart-empty" data-facets-grid>
        <p class="h3">{{ 'sections.collection.empty' | t }}</p>
      </div>
    {%- endif -%}
    {%- endpaginate -%}
  </div>
</section>

{% schema %}
{
  "name": "Collection",
  "settings": [
    { "type": "checkbox", "id": "show_banner_image", "label": "Show banner image", "default": true },
    { "type": "checkbox", "id": "show_description", "label": "Show description", "default": true },
    { "type": "range", "id": "products_per_page", "label": "Products per page", "min": 8, "max": 36, "step": 4, "default": 16 },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns (desktop)",
      "options": [ { "value": "3", "label": "3" }, { "value": "4", "label": "4" } ],
      "default": "4"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [ { "value": "portrait", "label": "Portrait" }, { "value": "square", "label": "Square" }, { "value": "landscape", "label": "Landscape" } ],
      "default": "portrait"
    },
    { "type": "header", "content": "Navegación por categorías" },
    { "type": "checkbox", "id": "show_category_nav", "label": "Mostrar barra de categorías", "default": true },
    { "type": "link_list", "id": "category_menu", "label": "Menú de categorías (opcional)", "info": "Si se deja vacío, se listan todas las colecciones de la tienda." },
    { "type": "header", "content": "Filtrado" },
    { "type": "checkbox", "id": "enable_filtering", "label": "Activar filtros", "default": true },
    { "type": "checkbox", "id": "enable_sorting", "label": "Activar orden", "default": true },
    { "type": "checkbox", "id": "ajax_filtering", "label": "Filtrar sin recargar (AJAX)", "info": "Recomendado DESACTIVADO: recarga la pagina al filtrar y conserva las opciones en la URL. Mas fiable con imagenes por URL.", "default": false },
    { "type": "checkbox", "id": "enable_infinite_scroll", "label": "Scroll infinito (solo con AJAX)", "default": false }
  ]
}
{% endschema %}


{%- comment -%} DEEE TODO — Search results page. {%- endcomment -%}
{%- assign s = section.settings -%}
<section
  class="section"
  data-facets-container
  data-section-id="{{ section.id }}"
  data-infinite="false"
  aria-busy="false"
>
  <div class="container">
    <h1 class="h1" style="margin-bottom:1rem" data-split>{{ 'general.search.title' | t }}</h1>

    <form action="{{ routes.search_url }}" method="get" role="search" class="search-field {% if settings.glassmorphism %}glass{% endif %}" style="max-width:640px;margin-bottom:2rem">
      {% render 'icon', name: 'search' %}
      <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="{{ 'general.search.placeholder' | t }}" aria-label="{{ 'general.search.title' | t }}" data-predictive-input>
      <input type="hidden" name="type" value="product">
      <button type="submit" class="btn btn--primary btn--sm"><span class="btn__label">{{ 'general.search.submit' | t }}</span></button>
    </form>

    {%- if search.performed -%}
      {%- paginate search.results by s.results_per_page -%}
      {%- if search.results.size > 0 -%}
        <div class="cluster" style="justify-content:space-between;margin-bottom:1rem">
          <p class="text-muted">{{ 'general.search.results_for' | t: terms: search.terms }}</p>
          {%- if s.enable_sorting -%}{% render 'facets', results: search, enable_filtering: false, enable_sorting: true %}{%- endif -%}
        </div>
        <div class="product-grid product-grid--{{ s.columns }}" data-facets-grid>
          {%- for item in search.results -%}
            {%- if item.object_type == 'product' -%}
              {% render 'product-card', product: item, reveal: settings.scroll_reveal %}
            {%- else -%}
              <a href="{{ item.url }}" class="card" style="padding:1.5rem;display:block">
                <span class="badge">{{ item.object_type }}</span>
                <h3 class="h3" style="font-size:1.15rem;margin-top:.75rem">{{ item.title }}</h3>
                {%- if item.content %}<p class="text-muted" style="margin-top:.5rem">{{ item.content | strip_html | truncatewords: 20 }}</p>{% endif -%}
              </a>
            {%- endif -%}
          {%- endfor -%}
        </div>
        {% render 'pagination', paginate: paginate %}
      {%- else -%}
        <div class="cart-empty"><p class="h3">{{ 'general.search.no_results_html' | t: terms: search.terms }}</p></div>
      {%- endif -%}
      {%- endpaginate -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Search results",
  "settings": [
    { "type": "range", "id": "results_per_page", "label": "Results per page", "min": 8, "max": 36, "step": 4, "default": 16 },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns",
      "options": [ { "value": "3", "label": "3" }, { "value": "4", "label": "4" } ],
      "default": "4"
    },
    { "type": "checkbox", "id": "enable_sorting", "label": "Enable sorting", "default": true }
  ]
}
{% endschema %}


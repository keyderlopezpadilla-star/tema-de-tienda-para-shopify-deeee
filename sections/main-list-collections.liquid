{%- comment -%} DEEE TODO — All collections grid. {%- endcomment -%}
{%- liquid
  assign s = section.settings
  assign collections_list = collections
  if s.sort == 'alphabetical'
    assign collections_list = collections | sort: 'title'
  endif
-%}
<section class="section">
  <div class="container">
    <h1 class="display" style="font-size:clamp(2.2rem,5vw,4rem);margin-bottom:2.5rem" data-split>{{ s.heading | default: 'Colecciones' }}</h1>
    <div class="product-grid product-grid--{{ s.columns }}">
      {%- for collection in collections_list -%}
        <a href="{{ collection.url }}" class="product-card {% if settings.card_glow %}glow-ring{% endif %}" {% if settings.scroll_reveal %}data-reveal data-reveal-stagger{% endif %}>
          <div class="product-card__media">
            {%- if collection.image -%}
              {% render 'responsive-image', image: collection.image, ratio: 'square', sizes: '(min-width:990px) 25vw, 45vw' %}
            {%- elsif collection.products.first.featured_media -%}
              {% render 'responsive-image', image: collection.products.first.featured_media, ratio: 'square', sizes: '(min-width:990px) 25vw, 45vw' %}
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag: 'placeholder' }}
            {%- endif -%}
            <div style="position:absolute;inset:0;background:linear-gradient(0deg, rgba(var(--color-bg-rgb),.8), transparent 60%);display:flex;align-items:flex-end;padding:1.25rem">
              <div>
                <h3 class="h3" style="font-size:1.3rem">{{ collection.title }}</h3>
                <span class="text-muted mono" style="font-size:.8rem">{{ 'sections.collection.products_count' | t: count: collection.products_count }}</span>
              </div>
            </div>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "List collections",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Colecciones" },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns",
      "options": [ { "value": "3", "label": "3" }, { "value": "4", "label": "4" } ],
      "default": "3"
    },
    {
      "type": "select",
      "id": "sort",
      "label": "Sort",
      "options": [ { "value": "default", "label": "Default" }, { "value": "alphabetical", "label": "Alphabetical" } ],
      "default": "default"
    }
  ]
}
{% endschema %}


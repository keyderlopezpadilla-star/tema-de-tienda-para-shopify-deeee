{%- comment -%} DEEE TODO — Customer order detail. {%- endcomment -%}
<section class="section">
  <div class="container">
    <a href="{{ routes.account_url }}" class="mono text-muted link-underline" style="font-size:.82rem">← {{ 'customer.account.title' | t }}</a>
    <h1 class="h1" style="margin:1rem 0 .5rem" data-split>{{ 'customer.orders.order_number' | t: number: order.name }}</h1>
    <p class="text-muted mono" style="font-size:.85rem;margin-bottom:2rem">{{ order.created_at | date: '%d %B %Y, %H:%M' }}</p>

    <div class="card" style="padding:1.5rem;overflow-x:auto">
      <table style="width:100%;border-collapse:collapse;font-size:.9rem">
        <thead>
          <tr class="text-muted mono" style="text-align:left;font-size:.75rem;text-transform:uppercase;letter-spacing:.08em">
            <th style="padding:.75rem 1rem .75rem 0">Producto</th>
            <th style="padding:.75rem 1rem">Cantidad</th>
            <th style="padding:.75rem 0;text-align:right">Total</th>
          </tr>
        </thead>
        <tbody>
          {%- for line_item in order.line_items -%}
            <tr style="border-top:1px solid var(--color-line)">
              <td style="padding:.85rem 1rem .85rem 0">
                <a class="link-underline" href="{{ line_item.product.url }}">{{ line_item.title }}</a>
              </td>
              <td style="padding:.85rem 1rem">{{ line_item.quantity }}</td>
              <td style="padding:.85rem 0;text-align:right">{{ line_item.final_line_price | money }}</td>
            </tr>
          {%- endfor -%}
        </tbody>
        <tfoot>
          <tr style="border-top:1px solid var(--color-line-strong)"><td colspan="2" style="padding:.85rem 1rem .85rem 0" class="text-muted">Subtotal</td><td style="padding:.85rem 0;text-align:right">{{ order.line_items_subtotal_price | money }}</td></tr>
          <tr><td colspan="2" style="padding:.5rem 1rem .5rem 0" class="text-muted">Envío</td><td style="padding:.5rem 0;text-align:right">{{ order.shipping_price | money }}</td></tr>
          <tr><td colspan="2" style="padding:.85rem 1rem .85rem 0"><strong>Total</strong></td><td style="padding:.85rem 0;text-align:right"><strong>{{ order.total_net_amount | money }}</strong></td></tr>
        </tfoot>
      </table>
    </div>

    <div class="grid" style="grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:1.5rem;margin-top:1.5rem">
      <div class="card" style="padding:1.5rem">
        <h2 class="footer__col-title">Dirección de envío</h2>
        <div class="rte text-muted">{{ order.shipping_address | format_address }}</div>
      </div>
      <div class="card" style="padding:1.5rem">
        <h2 class="footer__col-title">Dirección de facturación</h2>
        <div class="rte text-muted">{{ order.billing_address | format_address }}</div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{ "name": "Order", "settings": [] }
{% endschema %}
